# AI platform
AIPLATFORM_API_KEY=
AIPLATFORM_BASE_URL=
AIPLATFORM_TIMEOUT=120

# Model
MODEL=
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=1000

# Agent
AGENT_NAME=Windows Incident Agent
USE_TOOL_CALLBACK=false
TOOL_CALLBACK_METHOD=
AGENT_ENABLE_LOCAL_MCP=true
AGENT_DEBUG=false

# Monitoring
PROMETHEUS_BASE_URL=http://localhost:9090
LOKI_BASE_URL=http://localhost:3100
MONITORING_TIMEOUT=10

# PowerShell MCP
POWERSHELL_EXECUTABLE=powershell
POWERSHELL_TIMEOUT=20
POWERSHELL_MAX_OUTPUT_CHARS=12000
POWERSHELL_MODE=readonly

# Runtime
PORT=10005
LOG_LEVEL=INFO
STREAMING=false
